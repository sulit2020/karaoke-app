generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_AWS")
}

model Queue {
  id         String   @id @default(uuid())
  videoId    String
  title      String
  thumbnail  String
  singerName String
  status     String   @default("waiting")
  createdAt  DateTime @default(now())
}